#!/usr/bin/env bash
# now — print the current instant as an ISO 8601 UTC timestamp, e.g. 2026-06-19T14:03:27Z.
#
# The agent and the scripts use this so timeliness comparisons (a demand vs when its source
# was last read, freshness, etc.) work at TIME granularity, not date, and so the time is real
# rather than guessed. ISO 8601 UTC strings compare chronologically with a plain string
# compare: a later instant is lexicographically greater, so `a > b` means a is newer than b.
exec date -u +%Y-%m-%dT%H:%M:%SZ
