{
  "permissions": {
    "deny": [
      "Write(./raw/**)",
      "Edit(./raw/**)",
      "MultiEdit(./raw/**)",
      "NotebookEdit(./raw/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Update|Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/scripts/guard-raw" }
        ]
      }
    ]
  }
}
