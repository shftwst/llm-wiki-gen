# OS / editor cruft
.DS_Store
Thumbs.db
*~

# Obsidian per-machine state (vault lives in wiki/)
.obsidian/
.trash/

# Mechanical-ingest run logs (manifest state IS committed; logs are not)
.ingest/auto.log

# inbox/ is transient staging (swept into raw/); don't commit drops, keep the dir + README
inbox/*
!inbox/README.md

# publish build artifacts (per-role staged content + generated sites); roles.tsv stays tracked
.publish/*/

# junk/ is a sweep holding pen for garbage; keep the dir + README, ignore the contents
junk/*
!junk/README.md
