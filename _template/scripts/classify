#!/usr/bin/env bash
# classify — estimate a sensitivity tier for each coverage item. No LLM, no cost.
#
#   ./scripts/classify            classify all coverage items, write .ingest/sensitivity.tsv
#   ./scripts/classify --dry-run  print the classification; write nothing
#
# Deterministic: it matches keywords in each coverage item's path and notes and never reads
# document contents (the "without reading the full document" case). Fail-safe: an item that
# matches no keyword falls to a conservative floor (CLASSIFY_FLOOR) so it is never
# under-classified.
#
# Tier names come from .kb/privilege-tiers.tsv: the keyword buckets map to whichever tiers are
# marked `personal` / `business` there, and the floor defaults to the `business` bucket. So a
# KB can rename or re-rank its tiers without editing this script. The keyword lists below are
# the domain heuristic; tune them per KB as needed.
#
# This is Phase 1 of the sensitivity-aware routing design (llm-wiki-kit docs/routing.md).
# It only TAGS; nothing routes on the tag yet. Sensitivity lives in its own sidecar ledger
# (not a coverage column) so it never collides with scan --refresh or the agent's row writes.

set -eu
KB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$KB_DIR/scripts/kblib.sh"   # privilege-tier vocabulary (.kb/privilege-tiers.tsv)
COVERAGE="$KB_DIR/.ingest/coverage.tsv"
SENS="$KB_DIR/.ingest/sensitivity.tsv"
DATE="$(date +%F)"
DRY=0; [ "${1:-}" = "--dry-run" ] && DRY=1

PERSONAL_TIER="$(kb_tier_for_bucket personal)"
BUSINESS_TIER="$(kb_tier_for_bucket business)"
FLOOR="${CLASSIFY_FLOOR:-$BUSINESS_TIER}"   # fail-safe default for unmatched items

[ -f "$COVERAGE" ] || { echo "classify: no coverage.tsv — run ./scripts/ingest --map first."; exit 0; }

tierlist="$(kb_tiers | paste -sd'|' - | sed 's/|/ | /g')"
HEADER="$(printf '# sensitivity.tsv — estimated sensitivity per coverage item (script-owned; written by scripts/classify).\n# Columns: item\ttier\tbasis\tdate     tier: %s\n# Deterministic path/keyword heuristic, fail-safe. Phase 1 of docs/routing.md; nothing routes on it yet.' "$tierlist")"

tier_for() {  # prints "tier<TAB>basis" for the lowercased text in $1
  case " $1 " in
    *t4*|*t5*|*payroll*|*" sin "*|*"social insurance"*|*passport*|*" hr "*|*employment*|*benefit*|*hsa*|*medical*|*salary*|*paystub*|*personal*)
      printf '%s\tpersonal / HR / payroll keyword' "$PERSONAL_TIER";;
    *tax*|*financ*|*statement*|*bank*|*invoice*|*contract*|*agreement*|*client*|*legal*|*minute*|*resolution*|*cap-table*|*insurance*|*gst*|*hst*|*option*|*dividend*)
      printf '%s\tbusiness / financial / legal keyword' "$BUSINESS_TIER";;
    *)
      printf '%s\tno keyword (fail-safe floor)' "$FLOOR";;
  esac
}

tmp="$(mktemp)"; trap 'rm -f "$tmp"' EXIT
printf '%s\n' "$HEADER" > "$tmp"
n=0
while IFS= read -r row; do
  case "$row" in ''|'#'*) continue;; esac
  item="${row%%	*}"
  res="$(tier_for "$(printf '%s' "$row" | tr 'A-Z' 'a-z')")"
  tier="${res%%	*}"; basis="${res#*	}"
  printf '%s\t%s\t%s\t%s\n' "$item" "$tier" "$basis" "$DATE" >> "$tmp"
  n=$((n + 1))
done < <(grep -v '^#' "$COVERAGE")

# per-tier breakdown, generalised over whatever tiers the KB defines
counts="$(for t in $(kb_tiers); do c="$(awk -F'\t' -v t="$t" '$1!~/^#/ && $2==t{k++} END{print k+0}' "$tmp")"; printf ' %s=%s' "$t" "$c"; done)"

if [ "$DRY" -eq 1 ]; then
  printf 'classify: [dry-run] %d items →%s (floor=%s). Nothing written.\n' "$n" "$counts" "$FLOOR"
  grep -v '^#' "$tmp" | cut -f1-2 | sed 's/^/  /'
  exit 0
fi
mv "$tmp" "$SENS"; trap - EXIT
printf 'classify: %d items →%s (floor=%s) → %s\n' "$n" "$counts" "$FLOOR" "${SENS#"$KB_DIR"/}"
